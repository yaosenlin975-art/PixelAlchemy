<?xml version="1.0" encoding="utf-8" ?>
<!-- NoitaCA 服务器框架配置文件 -->
<!-- NoitaCA server framework configuration file -->
<fantasy xmlns="http://fantasy.net/config"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://fantasy.net/config Fantasy.xsd">
  <!-- ↓这是为了兼容旧版Fantasy的导表Json配置↓, 如果这个XML节点被注释掉, 就会以 Fantasy.config 配置为准 -->
  <!--<configTable path="../../../../Config/Json/Server" />-->
  <!-- ↓这是目前推荐使用的Fantasy框架启服配置↓ -->
  <!-- 网络运行时配置 / Network runtime configuration -->
  <network inner="TCP" maxMessageSize="1048560" />
  <!-- 会话运行时配置 / Session runtime configuration -->
  <session idleTimeout="8000" idleInterval="5000" />
  <server>
    <!-- 机器配置 / Machine configuration -->
    <!-- 本地开发：单机部署 / Local development: single-machine deployment -->
    <machines>
      <machine id="1" outerIP="127.0.0.1" outerBindIP="127.0.0.1" innerBindIP="127.0.0.1" />
    </machines>
    <!-- 进程配置 / Process configuration -->
    <!-- 7-Scene 拓扑进程划分（spec 能力域 1）/ 7-Scene topology process partition (spec Capability Domain 1) -->
    <!-- 开发模式 -m Develop 下 Fantasy 自动合并所有 Scene 到单进程启动 / Under Develop mode, Fantasy auto-merges all Scenes to single process -->
    <!-- 生产模式需 -pid N 或 -g N 指定启动 process / Production mode requires -pid N or -g N to specify which processes to start -->
    <processes>
      <process id="1" machineId="1" startupGroup="0" />
      <process id="2" machineId="1" startupGroup="0" />
      <process id="3" machineId="1" startupGroup="0" />
      <process id="4" machineId="1" startupGroup="0" />
      <process id="5" machineId="1" startupGroup="0" />
      <process id="6" machineId="1" startupGroup="0" />
      <process id="7" machineId="1" startupGroup="0" />
    </processes>
    <!-- 世界配置 / World configuration -->
    <!-- MongoDB 连接串：S0-3 阶段实际连接本地 MongoDB 实例 / MongoDB connection string: actual connection to local MongoDB instance in S0-3 phase -->
    <worlds>
      <world id="1" worldName="NoitaCA">
        <database dbType="MongoDB" dbName="noitaca" dbConnection="mongodb://localhost:27017/" />
      </world>
    </worlds>
    <!-- 场景配置 / Scene configuration -->
    <!-- 7-Scene 拓扑：Gate/Login/Match/Game/Realm/Replay/Analytics / 7-Scene topology: Gate/Login/Match/Game/Realm/Replay/Analytics -->
    <!-- 协议归属：仅 Gate 监听外网 KCP，其他 6 个 Scene 走 Inner 协议 / Protocol: only Gate listens outer KCP, others use Inner protocol -->
    <scenes>
      <!-- Gate 场景：客户端唯一入口，鉴权后转发到内部 Scene / Gate scene: sole client entry, auth then forward to inner Scenes -->
      <scene id="1001" processConfigId="1" worldConfigId="1" sceneRuntimeMode="MultiThread" sceneTypeString="Gate" networkProtocol="KCP" outerPort="20000" innerPort="11001" />
      <!-- Login 场景：账号注册/登录/Token 签发/设备指纹上报 / Login scene: account/login/token/device fingerprint -->
      <scene id="1002" processConfigId="2" worldConfigId="1" sceneRuntimeMode="MultiThread" sceneTypeString="Login" networkProtocol="" outerPort="0" innerPort="11002" />
      <!-- Match 场景：匹配队列+房间管理+观战列表 / Match scene: matchmaking queue + room + spectator list -->
      <scene id="1003" processConfigId="3" worldConfigId="1" sceneRuntimeMode="MultiThread" sceneTypeString="Match" networkProtocol="" outerPort="0" innerPort="11003" />
      <!-- Game 场景：房间实体+帧中继+反作弊+结算+场景事件注入 / Game scene: room entity + frame relay + anti-cheat + settlement + scene event injection -->
      <scene id="1004" processConfigId="4" worldConfigId="1" sceneRuntimeMode="MultiThread" sceneTypeString="Game" networkProtocol="" outerPort="0" innerPort="11004" />
      <!-- Realm 场景：排行榜查询+MMR 季节管理+玩家档案查询 / Realm scene: leaderboard + MMR season + player profile -->
      <scene id="1005" processConfigId="5" worldConfigId="1" sceneRuntimeMode="MultiThread" sceneTypeString="Realm" networkProtocol="" outerPort="0" innerPort="11005" />
      <!-- Replay 场景：录像存储与回放分发 / Replay scene: replay storage and playback distribution -->
      <scene id="1006" processConfigId="6" worldConfigId="1" sceneRuntimeMode="MultiThread" sceneTypeString="Replay" networkProtocol="" outerPort="0" innerPort="11006" />
      <!-- Analytics 场景：埋点 ingestion+事件归档 / Analytics scene: telemetry ingestion + event archive -->
      <scene id="1007" processConfigId="7" worldConfigId="1" sceneRuntimeMode="MultiThread" sceneTypeString="Analytics" networkProtocol="" outerPort="0" innerPort="11007" />
    </scenes>
  </server>
</fantasy>
