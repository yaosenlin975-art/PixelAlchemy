<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="PluginToggle" style="flex-grow: 1; flex-direction: row; justify-content: space-between; -unity-slice-left: 0; border-left-width: 15px; border-right-width: 15px; background-color: rgba(0, 0, 0, 0.2); border-top-width: 1px; border-bottom-width: 1px; border-left-color: rgba(255, 255, 255, 0.05); border-right-color: rgba(255, 255, 255, 0.05); border-top-color: rgba(255, 255, 255, 0.05); border-bottom-color: rgba(255, 255, 255, 0.05);">
        <ui:Label tabindex="-1" text="Label" parse-escape-sequences="true" display-tooltip-when-elided="true" name="Name" style="width: auto;" />
        <ui:Toggle name="Toggle" />
    </ui:VisualElement>
</ui:UXML>
