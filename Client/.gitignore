# ============================================================
# NoitaCA Unity Project .gitignore
# 放置位置: d:\Unity\Projects\Noita\Client\.gitignore (Unity 仓库根)
# 创建日期: 2026-07-06
# ============================================================
# 此文件控制 Unity 项目中哪些文件不进入 git 历史。
# HEAD 中已跟踪的文件不受影响（gitignore 仅对未跟踪文件生效）。

# ----------------------------------------------------------
# Unity 生成的元数据与缓存
# ----------------------------------------------------------
# 标准 .NET / Unity 生成物
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ordings/
*.log
*.pidb
*.pidb.meta
*.pdb
*.pdb.meta
*.mdb
*.mdb.meta
*.opendb
*.VC.db
sysinfo.txt
mono_crash.*
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.sln.docstates
*.suo
*.tmp
*.user
*.userprefs
*.booproj
*.svd
*.unitypackage
*.unitypackage.meta
*.apk
*.aab
*.app

# Crashlytics / TestRunner 自动生成
crashlytics-build.properties
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
InitTestScene*.unity*
/[Aa]ssets/[Ss]ceneDependencyCache*

# 视觉脚本自动生成
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Addressables 默认忽略（参考官方模板）
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# 编辑器与 IDE 缓存
.vs/
.gradle/
*.DotSettings.user

# JetBrains Rider
/[Aa]ssets/Plugins/Editor/JetBrains*

# Blend 文件
*.blend1
*.blend1.meta

# 临时 / utmp
.utmp/

# ----------------------------------------------------------
# HybridCLR（已在 HEAD 中跟踪 hybirdclr_repo 与 il2cpp_plus_repo，
#             但应忽略 LocalIl2CppData 等本地编辑器产物）
# ----------------------------------------------------------
# LocalIl2CppData 是本地编辑器热重载产物，由 HybridCLR 在 Unity 打开时自动生成
/LocalIl2CppData-WindowsEditor/
/LocalIl2CppData-MacEditor/
/LocalIl2CppData-LinuxEditor/

# 注: hybridclr_repo/ 与 il2cpp_plus_repo/ 是从 GitHub clone 的源码引用,
#     项目选择跟踪它们以便离线开发。保留跟踪, 不忽略。

# ----------------------------------------------------------
# DOTS / Entities 生成物
# ----------------------------------------------------------
# Entities 客户端设置缓存
/ProjectSettings/EntitiesClientSettings.asset.meta
# Burst 编译缓存
/Library/BurstCache/
# EntitiesGraphics 临时构建
/[Tt]emp/Unity.Entities.Graphics.Build/

# ----------------------------------------------------------
# HybridCLR 运行时缓存
# ----------------------------------------------------------
# 避免被误忽略的清单
!*.asmdef
!*.asmref

# ----------------------------------------------------------
# Fantasy / NetworkProtocol 生成物
# ----------------------------------------------------------
# NetworkProtocol Generate 目录（协议导出工具生成，重复生成会覆盖）
# 默认情况下, Generate 目录不提交, 由协议工具本地生成
# 如果需要服务端/客户端共享同一份生成代码, 反注释下面行
# !Server/Entity/Generate/NetworkProtocol/**/
# !Client/Assets/Scripts/Hotfix/Generate/NetworkProtocol/**/

# ----------------------------------------------------------
# 操作系统与编辑器临时文件
# ----------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.swp
*.swo
*~
*.lock

# ----------------------------------------------------------
# 不要忽略的（白名单）
# ----------------------------------------------------------
# 即使在忽略目录中也要跟踪的项目关键文件
!/.gitattributes
!/.gitignore
!/.gitkeep
!/.editorconfig
!/.codegraph/.gitignore
!/README.md
!/LICENSE

# 跟踪 .meta 文件（Unity 必需）
!*.meta
